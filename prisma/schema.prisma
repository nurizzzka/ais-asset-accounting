generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model currencies {
  id      Int      @id @default(autoincrement())
  code    String   @unique @db.VarChar(3)
  symbol  String   @db.VarChar(5)
  name    String   @db.VarChar(50)
  is_base Boolean? @default(false)
}

model products {
  id                        Int         @id @default(autoincrement())
  name                      String      @db.VarChar(200)
  sku                       String?     @unique @db.VarChar(50)
  supplier_id               Int?
  quantity                  Int         @default(0)
  min_quantity              Int?        @default(0)
  unit                      String?     @default("шт") @db.VarChar(20)
  price_kgs                 Decimal?    @default(0) @db.Decimal(12, 2)
  purchase_currency_code    String?     @db.VarChar(3)
  purchase_price_original   Decimal?    @db.Decimal(12, 2)
  exchange_rate_at_purchase Decimal?    @db.Decimal(12, 4)
  notes                     String?
  created_at                DateTime?   @default(now()) @db.Timestamp(6)
  updated_at                DateTime?   @default(now()) @db.Timestamp(6)
  suppliers                 suppliers?  @relation(fields: [supplier_id], references: [id], onUpdate: NoAction)
  receipts                  receipts[]
  writeoffs                 writeoffs[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model receipts {
  id              Int       @id @default(autoincrement())
  product_id      Int
  quantity        Int
  price_original  Decimal   @db.Decimal(12, 2)
  currency_code   String    @db.VarChar(3)
  exchange_rate   Decimal   @db.Decimal(12, 4)
  price_kgs       Decimal?  @default(dbgenerated("(price_original * exchange_rate)")) @db.Decimal(12, 2)
  total_kgs       Decimal?  @default(dbgenerated("(((quantity)::numeric * price_original) * exchange_rate)")) @db.Decimal(15, 2)
  document_number String?   @db.VarChar(50)
  receipt_date    DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_by      Int?
  notes           String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  users           users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products        products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model suppliers {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(200)
  phone      String?    @db.VarChar(50)
  email      String?    @db.VarChar(100)
  address    String?
  inn        String?    @db.VarChar(20)
  notes      String?
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  products   products[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id            Int         @id @default(autoincrement())
  username      String      @unique @db.VarChar(50)
  password_hash String      @db.VarChar(255)
  full_name     String      @db.VarChar(100)
  email         String?     @db.VarChar(100)
  role          String      @db.VarChar(20)
  is_active     Boolean?    @default(true)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  updated_at    DateTime?   @default(now()) @db.Timestamp(6)
  receipts      receipts[]
  writeoffs     writeoffs[]
}

model writeoff_reasons {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?
  is_active   Boolean? @default(true)
}

model writeoffs {
  id                Int       @id @default(autoincrement())
  product_id        Int
  quantity          Int
  reason_id         Int?
  reason_text       String?
  price_at_writeoff Decimal   @db.Decimal(12, 2)
  currency_code     String    @db.VarChar(3)
  total_amount      Decimal?  @db.Decimal(15, 2)
  document_number   String?   @db.VarChar(50)
  writeoff_date     DateTime? @db.Date
  created_by        Int?
  notes             String?
  created_at        DateTime? @db.Timestamp(6)
  users             users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "created_by_fkey")
  products          products  @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "product_id_fkey")
}
